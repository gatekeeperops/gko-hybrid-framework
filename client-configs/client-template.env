# GKO Hybrid Framework — Client Configuration Template
# Copy this file to .env and fill in client-specific values.
# IMPORTANT: Use TEST_USERNAME not USERNAME — USERNAME is a reserved
# Windows system variable and will always be overridden by the OS.

CLIENT_NAME=client-name
ENV_NAME=staging
BASE_URL=https://app.clientname.com
API_BASE_URL=https://api.clientname.com
AUTH_TYPE=bearer
TEST_USERNAME=testuser@clientname.com
TEST_PASSWORD=testpassword
API_TOKEN=
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000
ALLURE_RESULTS_DIR=allure-results